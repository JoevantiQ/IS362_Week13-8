   "cell_type": "markdown",
   "source": "Convery to numeric value",
   "id": "abd566d7eeade0aa"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-04-23T20:25:28.838679089Z",
     "start_time": "2026-04-23T20:25:28.779804558Z"
    }
   },
   "cell_type": "code",
   "source": [
    "df_subset = df[[\"class\", \"odor\", \"cap_color\"]].copy()\n",
    "\n",
    "\n",
    "df_subset.columns = [\"edible\", \"odor\", \"cap_color\"]\n",
    "\n",
    "df_subset[\"edible\"] = df_subset[\"edible\"].map({\"e\": 0, \"p\": 1})\n",
    "\n",
    "odor_mapping = {\n",
    "    \"a\": 0, \"l\": 1, \"c\": 2, \"y\": 3, \"f\": 4,\n",
    "    \"m\": 5, \"n\": 6, \"p\": 7, \"s\": 8\n",
    "}\n",
    "df_subset[\"odor\"] = df_subset[\"odor\"].map(odor_mapping)\n",
    "\n",
    "cap_color_mapping = {\n",
    "    \"n\": 0, \"b\": 1, \"c\": 2, \"g\": 3,\n",
    "    \"r\": 4, \"p\": 5, \"u\": 6, \"e\": 7,\n",
    "    \"w\": 8, \"y\": 9\n",
    "}\n",
    "df_subset[\"cap_color\"] = df_subset[\"cap_color\"].map(cap_color_mapping)"
   ],
   "id": "7eec88c46ba76e37",
